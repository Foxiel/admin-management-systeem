@model KE03_INTDEV_SE_2_Base.Controllers.ProductController.ProductEditModel

@{
    ViewData["Title"] = "Nieuw product";
}

<div class="crud-container">
    <h1 class="crud-title">Nieuw product</h1>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="EAN" class="control-label">EAN</label>
            <input asp-for="EAN" class="form-control" />
            <span asp-validation-for="EAN" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Naam" class="control-label">Naam</label>
            <input asp-for="Naam" class="form-control" />
            <span asp-validation-for="Naam" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LeverancierId" class="control-label">Leverancier</label>
            <select asp-for="LeverancierId" asp-items="ViewBag.Leveranciers" class="form-select">
                <option value="0">-- Selecteer leverancier --</option>
            </select>
            <span asp-validation-for="LeverancierId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Beschrijving" class="control-label">Beschrijving</label>
            <textarea asp-for="Beschrijving" class="form-control" rows="3" placeholder="Korte omschrijving"></textarea>
            <span asp-validation-for="Beschrijving" class="text-danger"></span>
        </div>

        <div class="form-row d-flex gap-2 mt-2">
            <div class="form-group" style="width:120px">
                <label class="control-label">Prijs</label>
                <input asp-for="Prijs" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group" style="width:140px">
                <label class="control-label">Huidige voorraad</label>
                <input asp-for="HuidigeVoorraad" class="form-control" type="number" />
            </div>

            <div class="form-group" style="width:140px">
                <label class="control-label">Minimum voorraad</label>
                <input asp-for="MinimumVoorraad" class="form-control" type="number" />
            </div>

            <div class="form-group flex-fill">
                <label class="control-label">Status</label>
                <input asp-for="Status" class="form-control" />
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn-success">Opslaan</button>
            <a asp-controller="Product" asp-action="Index" class="details-link ms-2">Annuleren</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}