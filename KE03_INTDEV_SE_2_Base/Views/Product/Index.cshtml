@model IEnumerable<KE03_INTDEV_SE_2_Base.Controllers.ProductController.ProductListItem>

@{
    ViewData["Title"] = "Producten";
    var leveranciers = ViewBag.Leveranciers as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
    /* view-local tweaks */
    /* make column sizes dynamic (percent-based) so layout adapts */
    .col-ean { width: 12%; max-width: 12%; }
    .col-name { width: 30%; min-width: 20%; }
    .col-supplier { width: 18%; }
    .col-location { width: 12%; }
    .col-price { width: 10%; }
    .col-stock { width: 12%; }
    .col-status { width: 10%; }
    .col-actions { width: 6%; min-width: 100px; }

    .truncate {
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        display: block;
        max-width: 100%;
    }

    /* enforce table-layout: fixed to make truncation predictable,
       but let columns be percentage-based so they scale */
    table.table { table-layout: fixed; }

    /* make icon-only buttons visually consistent and not oversized */
    .product-page .crud-icon-btn.icon-only {
        width: 40px;
        height: 40px;
        padding: 0;
    }

    /* ensure small screens wrap nicely */
    @@media (max-width: 768px) {
        .col-ean, .col-price, .col-stock, .col-status, .col-actions, .col-location, .col-supplier {
            width: auto;
            max-width: none;
        }
        .col-name { width: auto; }
    }
</style>

<div class="crud-container product-page">
    <div class="crud-header">
        <div class="header-left">
            <h1 class="crud-title">Producten</h1>

            <a asp-controller="Product" asp-action="Create" class="details-link create-link">
                <svg class="icon-svg plus-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" fill="none" />
                    <path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                Nieuw product
            </a>
        </div>

        <div class="search-form">
            <form method="get" class="d-flex align-items-center" style="gap:8px;">
                <input type="text" name="naam" class="search-input" placeholder="Zoeken op naam..." value="@Context.Request.Query["naam"]" />
                <button type="button" id="filterToggle" class="details-link">Filters</button>
            </form>
        </div>
    </div>

    <hr />

    <div id="advancedFilters" class="mb-3" style="display:none;">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">EAN</label>
                <input class="form-control" name="ean" value="@Context.Request.Query["ean"]" />
            </div>

            <div class="col-md-2">
                <label class="form-label small">Leverancier</label>
                <select class="form-select" name="leverancierNaam">
                    <option value="">-- Alle leveranciers --</option>
                    @foreach (var i in leveranciers)
                    {
                        var selected = Context.Request.Query["leverancierNaam"] == i.Value;
                        <option value="@i.Value" selected="@(selected ? "selected" : null)">@i.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-1">
                <label class="form-label small">Min €</label>
                <input class="form-control" name="minPrijs" value="@Context.Request.Query["minPrijs"]" />
            </div>

            <div class="col-md-1">
                <label class="form-label small">Max €</label>
                <input class="form-control" name="maxPrijs" value="@Context.Request.Query["maxPrijs"]" />
            </div>

            <div class="col-md-2">
                <label class="form-label small">Max voorraad</label>
                <input class="form-control" name="huidigeVoorraadMax" value="@Context.Request.Query["huidigeVoorraadMax"]" />
            </div>

            <div class="col-md-2">
                <label class="form-label small">Status</label>
                <input class="form-control" name="status" value="@Context.Request.Query["status"]" />
            </div>

            <div class="col-md-2 d-flex" style="gap:8px;">
                <button type="submit" class="details-link">Filter</button>
                <a asp-controller="Product" asp-action="Index" class="details-link">Reset</a>
            </div>
        </form>
    </div>

    <div class="table-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th class="col-ean">EAN</th>
                    <th class="col-name">Naam</th>
                    <th class="col-supplier">Leverancier</th>
                    <th class="col-location">Locatie</th>
                    <th class="col-price">Prijs</th>
                    <th class="col-stock">Voorraad</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions">Acties</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="col-ean"><span class="truncate">@item.EAN</span></td>
                        <td class="col-name"><span class="truncate">@item.Naam</span></td>
                        <td class="col-supplier"><span class="truncate">@item.LeverancierNaam</span></td>
                        <td class="col-location"><span class="truncate">@item.LocatieNaam</span></td>
                        <td class="col-price">@item.Prijs.ToString("C")</td>
                        <td class="col-stock">@item.HuidigeVoorraad</td>
                        <td class="col-status">@item.Status</td>
                        <td class="action-buttons">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="details-link">Details</a>

                            <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.ProductId" class="crud-icon-btn icon-only edit-btn" title="Bewerken">
                                <svg class="icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                                          d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                                </svg>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const toggle = document.getElementById('filterToggle');
            const adv = document.getElementById('advancedFilters');

            if (!toggle || !adv) return;

            toggle.addEventListener('click', function () {
                if (adv.style.display === 'none' || adv.classList.contains('d-none')) {
                    adv.style.display = 'block';
                    adv.classList.remove('d-none');
                } else {
                    adv.style.display = 'none';
                    adv.classList.add('d-none');
                }
            });

            // Auto-open filters if any filter param present
            const urlParams = new URLSearchParams(window.location.search);
            const keys = ['ean','leverancierNaam','minPrijs','maxPrijs','huidigeVoorraadMax','status'];
            for (const k of keys) {
                if (urlParams.get(k)) {
                    adv.style.display = 'block';
                    adv.classList.remove('d-none');
                    break;
                }
            }
        })();
    </script>
}