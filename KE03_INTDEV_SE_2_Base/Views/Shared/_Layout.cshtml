<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KE03_INTDEV_SE_2_Base</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KE03_INTDEV_SE_2_Base.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="top-navbar">
			<button id="menuToggle" class="hamburger-btn" type="button" aria-expanded="true">
				☰
			</button>
            <a class="navbar-brand"
               asp-controller="Home"
               asp-action="Index">
                TERUG NAAR DE MATRIX
            </a>
        </nav>
    </header>
   
    <nav class="sidebar" id="sidebar">
        <ul class="sidebar-list">
            <li><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
			<li><a asp-controller="Category" asp-action="Index">Categorieën</a></li>
            <li><a asp-controller="Customers" asp-action="Index">Klanten</a></li>
            <li><a href="#" onclick="alert('Onder constructie');">Medewerker</a></li>
			<li><a asp-controller="Orders" asp-action="Index">Bestellingen</a></li>
            <li><a asp-controller="Product" asp-action="Index">Producten</a></li>
            <li><a asp-controller="Leverancier" asp-action="Index">Leveranciers</a></li>
        </ul>
    </nav>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>