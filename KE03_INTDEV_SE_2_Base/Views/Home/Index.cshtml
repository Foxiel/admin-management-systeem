</section>

<section class="dashboard-overzicht-rij" aria-label="Overzicht retouren voorraden en orders">
    <article class="dashboard-overzicht-box">
        <h3>Retouren</h3>
        <div class="dashboard-overzicht-regel">
            <span>Open retouren</span>
            <strong>8</strong>
        </div>
        <div class="dashboard-overzicht-regel">
            <span>In verwerking</span>
            <strong>3</strong>
        </div>
    </article>

    <article class="dashboard-overzicht-box">
        <h3>Voorraden</h3>
        <div class="dashboard-overzicht-regel">
            <span>Producten met lage voorraad</span>
            <strong>12</strong>
        </div>
        <div class="dashboard-overzicht-regel">
            <span>Niet op voorraad</span>
            <strong>4</strong>
        </div>
    </article>

    <article class="dashboard-overzicht-box">
        <h3>Orders</h3>
        <div class="dashboard-overzicht-regel">
            <span>Open orders</span>
            <strong>15</strong>
        </div>
        <div class="dashboard-overzicht-regel">
            <span>In verwerking</span>
            <strong>6</strong>
        </div>
    </article>
</section>

