@* Aangepast door Fabian, Namen van het model aangepast *@

@model DataAccessLayer.Models.Customer

@{
    ViewData["Title"] = "Details";
}

<div class="crud-container">

    <h1 class="crud-title">
        Klant Details
    </h1>
<div>
        <div class="details-header">

            <h4>Klant</h4>

            <a asp-action="Edit"
               asp-route-id="@Model?.Id"
               class="crud-icon-btn icon-only edit-btn">

                <svg class="icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                          d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                </svg>

            </a>

        </div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Naam)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Naam)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Email)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Telefoonnr)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Telefoonnr)
        </dd>
    </dl>
</div>
<div>
       
    <a asp-action="Index" class="details-link">Terug</a>
</div>
</div>
