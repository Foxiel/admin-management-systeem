@model DataAccessLayer.Models.Order

@{
    ViewData["Title"] = "Details";
}

<div class="crud-container product-page">

    <h1 class="crud-title">Bestelling Details</h1>

    <div class="details-header">
        <div>
            <h4>Bestelling</h4>
        </div>
    </div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Order ID</dt>
        <dd class = "col-sm-10">@Model.Id</dd>

        <dt class = "col-sm-2">Klant naam</dt>
        <dd class = "col-sm-10">@Model.Klant?.Naam</dd>

        <dt class = "col-sm-2">Klant email</dt>
        <dd class = "col-sm-10">@Model.Klant?.Email</dd>

        <dt class = "col-sm-2">Klant telefoon</dt>
        <dd class = "col-sm-10">@Model.Klant?.Telefoonnr</dd>

        <dt class = "col-sm-2">Aantal producten</dt>
        <dd class = "col-sm-10">@Model.Producten?.Count ?? 0</dd>

        <dt class="col-sm-2">Besteldatum</dt>
        <dd class="col-sm-10">@Model.BestelDatum.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-2">Bestelstatus</dt>
        <dd class="col-sm-10">@Model.BestelStatus</dd>
    </dl>

    @if (Model.Producten != null && Model.Producten.Any())
    {
        <hr />
        <h4 class="crud-subtitle">Producten in deze bestelling</h4>

        <div class="table-wrapper">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>EAN</th>
                        <th>Naam</th>
                        <th style="width:120px">Prijs</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Producten)
                    {
                        <tr>
                            <td class="truncate">@p.EAN</td>
                            <td class="truncate">@p.Naam</td>
                            <td>@p.Prijs.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <hr />
        <p>Geen producten gevonden voor deze bestelling.</p>
    }

    <div class="mt-3 d-flex justify-content-start align-items-center gap-2">
        <a asp-action="Edit" asp-route-orderid="@Model.Id" class="details-link">Bewerken</a>
        <a asp-action="Index" class="details-link ms-2">Terug</a>
    </div>
</div>
