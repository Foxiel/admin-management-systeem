@model List<DataAccessLayer.Models.SendOrder>

@{
    ViewData["Title"] = "Bestellingen verzenden";
}

<div class="crud-container">
    <div class="crud-header">
        <div class="header-left">
            <h1 class="crud-title">Bestellingen verzenden</h1>
        </div>
    </div>

    <p class="crud-subtitle">
        Hieronder staan alle bestellingen met de status "Nog niet verzonden".
    </p>

    <div class="table-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th>Bestelling</th>
                    <th>Klant</th>
                    <th>Email</th>
                    <th>Adres</th>
                    <th>Orderdatum</th>
                    <th>Status</th>
                    <th>Actie</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="7">Er zijn geen bestellingen om te verzenden.</td>
                    </tr>
                }
                else
                {
                    foreach (var order in Model)
                    {
                        <tr>
                            <td>#@order.BestellingId</td>
                            <td>@order.KlantNaam</td>
                            <td>@order.KlantEmail</td>
                            <td>
                                @order.Adres<br />
                                @order.Postcode @order.Woonplaats<br />
                                @order.Land
                            </td>
                            <td>@order.OrderDatum.ToString("dd-MM-yyyy")</td>
                            <td>@order.OrderStatus</td>
                            <td>
                                <a asp-controller="SendOrder"
                                   asp-action="Create"
                                   asp-route-id="@order.BestellingId"
                                   class="details-link">
                                    Verzenden
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>