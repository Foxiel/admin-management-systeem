@model DataAccessLayer.Models.Leverancier

@{
    ViewData["Title"] = "Create";
}

<div class="crud-container">

    <h1 class="crud-title">Nieuwe Leverancier</h1>

    <form asp-action="Create">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Naam" class="control-label"></label>
            <input asp-for="Naam" class="form-control" />
            <span asp-validation-for="Naam" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <input type="submit" value="Opslaan" class="btn btn-success" />

            <a asp-action="Index" class="details-link">
                Terug
            </a>
        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
